# TARDIS Backend Environment Variables
# Copy this file to .env and fill in the values

# Solana RPC Configuration (Helius, QuickNode, etc.)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Database Configuration (Supabase PostgreSQL Connection String)
DATABASE_URL=postgresql://postgres.USER:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Pinata IPFS Configuration (For image uploads and metadata)
PINATA_JWT=YOUR_LONG_PINATA_JWT_HERE
PINATA_GATEWAY=teal-additional-lemming-515.mypinata.cloud
PINATA_API_KEY=YOUR_API_KEY
PINATA_SECRET=YOUR_API_SECRET

# Server Configuration
PORT=8085
NODE_ENV=development

# Optional: GCS (Google Cloud Storage) Configuration if used
GCS_BUCKET_NAME=
SERVICE_ACCOUNT_EMAIL=

# Turnkey Configuration (If using Turnkey for sub-wallets)
TURNKEY_ORGANIZATION_ID=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
